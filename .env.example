# =============================================================================
# Homelab Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your system.
# Run `id` to find your PUID and PGID values.

# User/Group IDs - must match your system user for correct file permissions
PUID=1000
PGID=1000

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/Toronto

# =============================================================================
# Paths
# =============================================================================

# Container configuration storage (relative to compose.yml)
APPDATA=./appdata

# Media and downloads root (external drive recommended)
DATA_DIR=/srv/data

# Server IP or hostname (used for service URLs in Dashy)
HOST_ADDR=10.0.0.100

# =============================================================================
# Immich (Photo Management)
# =============================================================================

# Immich version - use 'release' for latest stable
IMMICH_VERSION=release

# Photo/video upload storage (under your media tree)
UPLOAD_LOCATION=/srv/data/media/photos

# PostgreSQL database storage (keep on local disk, not network share)
DB_DATA_LOCATION=./appdata/immich/postgres

# Database credentials (alphanumeric password only)
DB_PASSWORD=change-me-to-a-secure-password
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
