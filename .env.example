# =============================================================================
# Homelab Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your system
# Run `id` to find your PUID and PGID values

# User/Group IDs - must match your system user for file permissions
PUID=1000
PGID=1000

# Timezone - see: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Montreal

# =============================================================================
# Paths
# =============================================================================

# Container configuration storage (relative to compose.yml)
APPDATA=./appdata

# Media and downloads storage
DATA_DIR=/srv/data

# Server address for service URLs (your server's IP or hostname)
HOST_ADDR=http://10.0.0.100

# =============================================================================
# Immich (Photo Management)
# =============================================================================

# Immich version - use 'release' for latest stable
IMMICH_VERSION=release

# Photo/video upload storage location
UPLOAD_LOCATION=/srv/photos

# PostgreSQL database storage
DB_DATA_LOCATION=./appdata/immich-db

# Database credentials (change the password!)
DB_PASSWORD=change-me-to-a-secure-password
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
